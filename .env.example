# OpenAI API Key (required for receipt OCR)
OPENAI_API_KEY=sk-your-api-key-here

# OpenAI Base URL (optional, for OpenAI-compatible APIs like Azure, Ollama, etc.)
# OPENAI_BASE_URL=https://your-endpoint.openai.azure.com/openai/deployments/gpt-4o

# OpenAI Model (optional, default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Redis URL (optional, uses in-memory store if not set)
# REDIS_URL=redis://localhost:6379

# Session TTL in seconds (default: 30 days)
SESSION_TTL=2592000
