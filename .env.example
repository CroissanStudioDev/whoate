# OpenAI API Key (required for receipt OCR)
# For OpenRouter: sk-or-v1-your-key
# For OpenAI: sk-your-key
OPENAI_API_KEY=sk-or-v1-your-openrouter-key

# OpenAI Base URL (recommended: OpenRouter for best price/quality)
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Model for OCR (default: Gemini 3.1 Flash - best accuracy for receipts)
OPENAI_MODEL=google/gemini-3.1-flash-image-preview

# Redis URL (optional, uses in-memory store if not set)
# REDIS_URL=redis://localhost:6379

# Session TTL in seconds (default: 30 days)
SESSION_TTL=2592000
